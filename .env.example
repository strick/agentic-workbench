# Agentic Workbench — local environment config
# Copy this file to .env.local and fill in machine-specific paths.
# .env.local is gitignored and must never be committed.
#
# Every value here can also be set (and is more easily managed) from the
# Settings page in the web UI, which writes local-config.json (also gitignored).
# Precedence: local-config.json > .env.local > defaults.

# Where the app keeps its own local state (SQLite metadata, fallback output folders).
WORKBENCH_DATA_DIR=./data

# Your existing skills folder. Defaults to ./.copilot/skills or ~/.copilot/skills if present.
# Example: C:\Users\bjstrick\.copilot\skills
WORKBENCH_SKILLS_DIR=

# Obsidian vault root (read-only reference in MVP).
# Example: C:\Users\bjstrick\Documents\Obsidian Notes\Personal\Work
WORKBENCH_OBSIDIAN_VAULT_DIR=

# Where finished daily work logs are written.
# Example: C:\Users\bjstrick\Documents\Obsidian Notes\Personal\Work\Daily
WORKBENCH_DAILY_LOG_DIR=

# Where weekly director reports are written.
# Example: C:\Users\bjstrick\Documents\Obsidian Notes\Personal\Work\Reports
WORKBENCH_WEEKLY_REPORT_DIR=

# Where sanitized wiki/canon source notes are written.
# Example: C:\Users\bjstrick\Documents\Obsidian Notes\Personal\Work\Projects\ai-platform-canon
WORKBENCH_WIKI_SOURCE_DIR=

# Default execution provider: mock | claude-cli | copilot-cli
WORKBENCH_DEFAULT_PROVIDER=mock

# CLI command paths (or bare command names resolvable on PATH). Optional.
CLAUDE_CLI_PATH=
COPILOT_CLI_PATH=

# Web server bind (defaults shown). Port 3000 is often taken by Docker; default is 3220.
WORKBENCH_PORT=3220
WORKBENCH_HOST=127.0.0.1
